APP_NAME="HME Fact"
API_V1_PREFIX="/api/v1"
ENVIRONMENT="local"
DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

POSTGRES_HOST="postgres"
POSTGRES_PORT=5432
POSTGRES_DB="hme_fact"
POSTGRES_USER="hme_fact"
POSTGRES_PASSWORD="hme_fact"

REDIS_URL="redis://redis:6379/0"

JWT_SECRET_KEY="change-this-secret-before-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

LOG_LEVEL="INFO"

FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="ChangeMe123!"
FIRST_SUPERUSER_FULL_NAME="Platform Admin"

SII_BASE_URL="https://api.sii.example.local"

# Celery Configuration
CELERY_BROKER_URL="redis://redis:6379/2"
CELERY_RESULT_BACKEND="redis://redis:6379/2"

# Email Notification Configuration (MailHog)
SMTP_HOST="mailhog"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@hmefact.cl"

# File Storage Configuration
FILE_STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="/tmp/hme_fact_storage"

# PDF Rendering Configuration
PDF_RENDERER="xhtml2pdf"

# Security Configuration
CERTIFICATE_ENCRYPTION_KEY="replace-this-with-a-32-byte-key!"
